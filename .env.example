# APDL Local Development Environment
# Copy to .env and fill in any missing values:  cp .env.example .env

# ── Infrastructure ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Shared Redis fails writes instead of evicting accepted stream data. The writer
# warns at 75% of this aggregate ceiling; size it for event backlog plus caches.
APDL_REDIS_MAXMEMORY=1gb
POSTGRES_URL=postgresql://apdl:apdl_dev@localhost:5432/apdl
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_NATIVE_URL=clickhouse://apdl:apdl_dev@localhost:9000/apdl
CLICKHOUSE_USER=apdl
CLICKHOUSE_PASSWORD=apdl_dev
CLICKHOUSE_DB=apdl

# ── Service URLs (for inter-service communication) ──────────────────
QUERY_SERVICE_URL=http://localhost:8082
CONFIG_SERVICE_URL=http://localhost:8081
CODEGEN_SERVICE_URL=http://localhost:8084

# Explicitly insecure local-only bootstrap credential. init-postgres.sh stores
# only its SHA-256 hash. Local smoke tests and service calls reuse this key.
APDL_DEV_API_KEY=proj_demo_0123456789abcdef0123456789abcdef

# Browser-safe local credential. It is provisioned with exactly events:write
# and config:read; it cannot call admin, query, agents, or codegen APIs.
APDL_DEV_CLIENT_KEY=client_demo_0123456789abcdef0123456789abcdef

# Admin browser sessions are served over HTTP only in local development.
# Production must use HTTPS and leave APDL_ADMIN_COOKIE_SECURE=true.
APDL_ADMIN_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5174"]
APDL_ADMIN_COOKIE_SECURE=false

# Automatic guardrail mutation is disabled in the OSS developer preview.
# ── LLM provider keys (Agents + Codegen) ────────────────────────────
# At least one is required for the agents service. Actual Codegen changesets also
# require the provider credential matching CODEGEN_MODEL; merely starting the
# full development stack does not exercise the model.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Optional OpenAI-compatible local endpoint used by Agents.
LOCAL_LLM_URL=

# ── Codegen Service (GitHub App) ────────────────────────────────────
# Actual Codegen changesets require a registered GitHub App, its installation on
# the target repository, and an active operator-created repository grant. Provide
# the private key in ONE of these ways (checked in this order):
#   1) GITHUB_APP_PRIVATE_KEY         inline PEM (escaped \n is accepted)
#   2) GITHUB_APP_PRIVATE_KEY_BASE64  base64 of the .pem — easiest for Docker/.env:
#                                       base64 -w0 your-app.private-key.pem
#   3) GITHUB_APP_PRIVATE_KEY_PATH    path to the .pem (~ allowed; for Docker, mount it)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_API_URL=https://api.github.com
# Required to enable POST /webhooks/github. Empty keeps the endpoint fail-closed;
# the default CI poller continues to recover GitHub state without webhooks.
GITHUB_WEBHOOK_SECRET=
# Code-automation kill switch: CODEGEN_KILL_SWITCH=true halts all changeset
# jobs; CODEGEN_DISABLED_PROJECTS is a comma-separated per-project denylist.
CODEGEN_KILL_SWITCH=
CODEGEN_DISABLED_PROJECTS=
# Coding-agent model — Aider via LiteLLM. Any LiteLLM model id works (e.g.
# gpt-4o, gemini/gemini-1.5-pro, ollama/…); set the matching provider key above.
CODEGEN_MODEL=claude-opus-4-8
# The base Compose service is deliberately offline and ignores attempts to turn
# publication on through `.env`. `make dev-all` and `scripts/dev.sh up-full`
# opt into this same non-publishing service without a Docker socket. No supported
# developer-preview command enables development_pr, reviewed_pr, or canary
# publication.
#
# Evaluated reviewed_pr/low_risk_canary deployments instead use an immutable
# orchestration identity and a read-only operator bundle for the exact model,
# revision, image identities, and behavior configuration.
CODEGEN_REVISION=development-unversioned
CODEGEN_ROLLOUT_STAGE=offline
CODEGEN_ROLLOUT_AUTHORIZATION_PATH=
# Host-side operator artifacts created by `make evaluate-codegen`. These are not
# service secrets, but the bundle is operator-controlled and must be mounted
# read-only. Leave blank for normal offline development; the Make targets derive
# a revision-scoped path under local-files/ when unset.
CODEGEN_EVALUATION_ARTIFACT_DIR=
CODEGEN_ROLLOUT_BUNDLE_PATH=
# Optional absolute path to a read-only platform_codegen_safety_policy@1 JSON
# file. Built-in safety limits and protected paths apply when unset.
CODEGEN_PLATFORM_SAFETY_POLICY_PATH=
# Auxiliary LLM passes around the edit (default on; skipped when LiteLLM or the
# provider key is absent): CODEGEN_BRIEF compiles the approved spec into a
# repo-grounded engineering brief before the edit; CODEGEN_REVIEW judges the
# produced diff against the spec before the push (a rejection feeds a retry).
# CODEGEN_HELPER_MODEL runs these passes on a different (e.g. cheaper) model
# than the editor; CODEGEN_EDIT_RETRIES bounds the verify/review feedback rounds.
CODEGEN_BRIEF=true
CODEGEN_REVIEW=true
CODEGEN_HELPER_MODEL=
CODEGEN_EDIT_RETRIES=1
# Behavior-affecting worker settings. Keep the same values during evaluation
# and reviewed deployment, and mint a new CODEGEN_REVISION when any changes.
CODEGEN_AIDER_BIN=aider
CODEGEN_REQUIRE_VERIFY=false
CODEGEN_CACHE_PROMPTS=true
CODEGEN_CONVENTIONS=true
CODEGEN_SDK_REFERENCE=false
CODEGEN_CONTRACTS=true
CODEGEN_CONTRACT_INSTALL_TIMEOUT=600
CODEGEN_TIMEOUT=1800
CODEGEN_GIT_TIMEOUT=300
CODEGEN_LLM_TIMEOUT=240
# Optional lower whole-container cap. Values above 3000 are rejected so the
# credential-bearing worker cannot outlive its GitHub installation token.
CODEGEN_JOB_BUDGET=3000
# CI-status poll interval (seconds). The zero-config way open changesets advance
# without a public webhook endpoint. Default 60; set 0 to disable when a GitHub
# webhook is wired instead.
CODEGEN_CI_POLL_INTERVAL=60
CODEGEN_CI_REPAIR_RETRIES=2
CODEGEN_CI_REPAIR_BUDGET_SECONDS=3600

# Isolated per-change workers are retained for experimental evaluation tooling.
# The supported developer-preview commands leave Codegen offline and do not
# build or launch a worker. Experimental evaluated PR stages require an
# operator-managed network that blocks APDL/private/metadata destinations while
# allowing the required GitHub/model endpoints.
CODEGEN_SANDBOX=docker
CODEGEN_SANDBOX_IMAGE=
CODEGEN_SANDBOX_NETWORK=
# Optional named filtered network for evaluation candidates. When unset the
# Docker evaluator uses the daemon default; publication deployments should use
# the same operator-managed restricted network as the production sandbox.
CODEGEN_EVALUATION_NETWORK=
CODEGEN_TRUSTED_REPOS_ONLY=false

# Docker-out-of-Docker operator settings used by the evaluated reviewed-PR
# overlay. `make codegen-reviewed-up` derives these from the current host. The
# normal development commands do not use these settings. When invoking reviewed
# Compose directly for experimental evaluation, use absolute paths/host IDs
# (`~` is not expanded).
CODEGEN_DOCKER_SOCKET=
CODEGEN_DOCKER_UID=
CODEGEN_DOCKER_GID=
CODEGEN_DOCKER_SOCKET_GID=

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info
