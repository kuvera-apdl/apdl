# APDL Local Development Environment
# Copy to .env and fill in any missing values:  cp .env.example .env

# ── Infrastructure ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql://apdl:apdl_dev@localhost:5432/apdl
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_NATIVE_URL=clickhouse://apdl:apdl_dev@localhost:9000/apdl
CLICKHOUSE_USER=apdl
CLICKHOUSE_PASSWORD=apdl_dev
CLICKHOUSE_DB=apdl

# ── Service URLs (for inter-service communication) ──────────────────
QUERY_SERVICE_URL=http://localhost:8082
CONFIG_SERVICE_URL=http://localhost:8081
CODEGEN_SERVICE_URL=http://localhost:8084
APDL_INTERNAL_TOKEN=apdl-dev-internal-token

# ── Guardrail Monitor ───────────────────────────────────────────────
GUARDRAIL_MONITOR_ENABLED=true
GUARDRAIL_PROJECT_IDS=apdl
GUARDRAIL_MONITOR_INTERVAL_SECONDS=60

# ── LLM provider keys (Agents + Codegen) ────────────────────────────
# At least one is required for the agents service; the codegen coding agent
# uses whichever matches CODEGEN_MODEL below.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Codegen Service (GitHub App) ────────────────────────────────────
# Created when the APDL GitHub App is registered. Provide the private key in ONE
# of these ways (checked in this order):
#   1) GITHUB_APP_PRIVATE_KEY         inline PEM (escaped \n is accepted)
#   2) GITHUB_APP_PRIVATE_KEY_BASE64  base64 of the .pem — easiest for Docker/.env:
#                                       base64 -w0 your-app.private-key.pem
#   3) GITHUB_APP_PRIVATE_KEY_PATH    path to the .pem (~ allowed; for Docker, mount it)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_API_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=
# Code-automation kill switch: CODEGEN_KILL_SWITCH=true halts all changeset
# jobs; CODEGEN_DISABLED_PROJECTS is a comma-separated per-project denylist.
CODEGEN_KILL_SWITCH=
CODEGEN_DISABLED_PROJECTS=
# Coding-agent model — Aider via LiteLLM. Any LiteLLM model id works (e.g.
# gpt-4o, gemini/gemini-1.5-pro, ollama/…); set the matching provider key above.
CODEGEN_MODEL=claude-opus-4-8

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info
