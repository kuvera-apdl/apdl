{
  "name": "@apdl/sdk",
  "version": "0.1.0",
  "description": "Client SDK for the Autonomous Product Development Loop platform",
  "type": "module",
  "main": "dist/apdl.cjs.js",
  "module": "dist/apdl.esm.js",
  "browser": "dist/apdl.iife.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/apdl.esm.js",
      "require": "./dist/apdl.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin typescript",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "rollup": "^4.12.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "tslib": "^2.6.0",
    "vitest": "^1.3.0",
    "jsdom": "^24.0.0",
    "@vitest/coverage-v8": "^1.3.0"
  },
  "sideEffects": false,
  "license": "MIT"
}
